# SpecGuard Environment Configuration
# Copy this to .env and fill in your values

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# Database URL
# For development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./specguard.db
# For production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/specguard

# AI Model Configuration
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.3
AI_MAX_RETRIES=2

# Server
HOST=0.0.0.0
PORT=8000
